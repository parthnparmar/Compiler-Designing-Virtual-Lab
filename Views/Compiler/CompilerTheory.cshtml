@{
    ViewData["Title"] = "Compiler Theory & Examples";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-3"><i class="fas fa-book me-2"></i>Compiler Theory & Examples</h2>
            <p class="lead">Complete demonstration of all compiler phases with theory and practical examples</p>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">1️⃣ Lexical Analysis</h4>
                </div>
                <div class="card-body">
                    <h5>Theory:</h5>
                    <p>Lexical analysis is the first phase of a compiler. It reads the source code as a stream of characters and converts it into meaningful tokens. The lexical analyzer (scanner) removes whitespace and comments, and identifies keywords, identifiers, operators, and literals.</p>
                    
                    <h5 class="mt-3">Example:</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Input:</h6>
                            <pre class="bg-light p-3 rounded"><code>int x = 10 + 20;</code></pre>
                        </div>
                        <div class="col-md-6">
                            <h6>Output (Tokens):</h6>
                            <table class="table table-bordered table-sm">
                                <thead class="table-light">
                                    <tr><th>Token</th><th>Type</th></tr>
                                </thead>
                                <tbody>
                                    <tr><td><code>int</code></td><td><span class="badge bg-primary">KEYWORD</span></td></tr>
                                    <tr><td><code>x</code></td><td><span class="badge bg-success">IDENTIFIER</span></td></tr>
                                    <tr><td><code>=</code></td><td><span class="badge bg-info">OPERATOR</span></td></tr>
                                    <tr><td><code>10</code></td><td><span class="badge bg-warning">CONSTANT</span></td></tr>
                                    <tr><td><code>+</code></td><td><span class="badge bg-info">OPERATOR</span></td></tr>
                                    <tr><td><code>20</code></td><td><span class="badge bg-warning">CONSTANT</span></td></tr>
                                    <tr><td><code>;</code></td><td><span class="badge bg-info">OPERATOR</span></td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">2️⃣ Syntax Analysis (Parsing)</h4>
                </div>
                <div class="card-body">
                    <h5>Theory:</h5>
                    <p>Syntax analysis checks whether the tokens generated by lexical analysis follow the grammar rules of the language. It creates a parse tree or syntax tree representing the grammatical structure of the source code.</p>
                    
                    <h5 class="mt-3">Example:</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Input:</h6>
                            <pre class="bg-light p-3 rounded"><code>x = a + b</code></pre>
                        </div>
                        <div class="col-md-6">
                            <h6>Parse Tree:</h6>
                            <pre class="bg-light p-3 rounded text-center" style="font-family: 'Courier New', monospace;">      =
     / \
    /   \
   x     +
        / \
       a   b</pre>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">3️⃣ Semantic Analysis</h4>
                </div>
                <div class="card-body">
                    <h5>Theory:</h5>
                    <p>Semantic analysis checks the semantic consistency of the code. It performs type checking, scope resolution, and ensures that operations are valid for the given operands. It also builds and maintains the symbol table.</p>
                    
                    <h5 class="mt-3">Example:</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Input:</h6>
                            <pre class="bg-light p-3 rounded"><code>int x = 10;
float y = x + 5.5;</code></pre>
                        </div>
                        <div class="col-md-6">
                            <h6>Semantic Checks:</h6>
                            <ul class="list-group">
                                <li class="list-group-item"><i class="fas fa-check-circle text-success"></i> Type checking: int + float = float</li>
                                <li class="list-group-item"><i class="fas fa-check-circle text-success"></i> Variable x is declared</li>
                                <li class="list-group-item"><i class="fas fa-check-circle text-success"></i> Type conversion: int → float</li>
                                <li class="list-group-item"><i class="fas fa-check-circle text-success"></i> Assignment valid: float = float</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">4️⃣ Intermediate Code Generation</h4>
                </div>
                <div class="card-body">
                    <h5>Theory:</h5>
                    <p>Intermediate code generation produces an intermediate representation (IR) of the source code. Three-Address Code (TAC) is a common form where each instruction has at most three operands. This makes optimization easier and provides platform independence.</p>
                    
                    <h5 class="mt-3">Example:</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Input:</h6>
                            <pre class="bg-light p-3 rounded"><code>x = a + b * c</code></pre>
                        </div>
                        <div class="col-md-6">
                            <h6>Three-Address Code:</h6>
                            <pre class="bg-light p-3 rounded"><code>t1 = b * c
t2 = a + t1
x = t2</code></pre>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">5️⃣ Code Optimization</h4>
                </div>
                <div class="card-body">
                    <h5>Theory:</h5>
                    <p>Code optimization improves the intermediate code to make it faster, smaller, or more efficient. Common techniques include constant folding, constant propagation, dead code elimination, and strength reduction.</p>
                    
                    <h5 class="mt-3">Example:</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Before Optimization:</h6>
                            <pre class="bg-light p-3 rounded"><code>t1 = 2 + 3
x = t1 * 4
y = x * 2</code></pre>
                        </div>
                        <div class="col-md-6">
                            <h6>After Optimization:</h6>
                            <pre class="bg-light p-3 rounded"><code>x = 20          // Constant folding
y = x + x       // Strength reduction</code></pre>
                        </div>
                    </div>
                    <div class="mt-3">
                        <h6>Optimization Techniques Applied:</h6>
                        <ul>
                            <li><strong>Constant Folding:</strong> 2 + 3 = 5, then 5 * 4 = 20</li>
                            <li><strong>Strength Reduction:</strong> x * 2 → x + x (addition is faster than multiplication)</li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white">
                    <h4 class="mb-0">6️⃣ Code Generation</h4>
                </div>
                <div class="card-body">
                    <h5>Theory:</h5>
                    <p>Code generation translates the optimized intermediate code into target machine code or assembly language. It involves instruction selection, register allocation, and instruction scheduling.</p>
                    
                    <h5 class="mt-3">Example:</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Intermediate Code:</h6>
                            <pre class="bg-light p-3 rounded"><code>t1 = a + b
x = t1</code></pre>
                        </div>
                        <div class="col-md-6">
                            <h6>Assembly Code:</h6>
                            <pre class="bg-dark text-light p-3 rounded"><code>LOAD  R1, a
LOAD  R2, b
ADD   R1, R1, R2
STORE x, R1</code></pre>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-secondary text-white">
                    <h4 class="mb-0">7️⃣ Symbol Table</h4>
                </div>
                <div class="card-body">
                    <h5>Theory:</h5>
                    <p>The symbol table is a data structure used throughout compilation to store information about identifiers (variables, functions, etc.). It contains details like name, type, scope, memory location, and other attributes.</p>
                    
                    <h5 class="mt-3">Example:</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Source Code:</h6>
                            <pre class="bg-light p-3 rounded"><code>int x = 10;
float y = 20.5;
int z = x + 5;</code></pre>
                        </div>
                        <div class="col-md-6">
                            <h6>Symbol Table:</h6>
                            <table class="table table-bordered table-sm">
                                <thead class="table-light">
                                    <tr><th>Name</th><th>Type</th><th>Scope</th><th>Value</th></tr>
                                </thead>
                                <tbody>
                                    <tr><td><code>x</code></td><td><span class="badge bg-info">int</span></td><td>global</td><td>10</td></tr>
                                    <tr><td><code>y</code></td><td><span class="badge bg-info">float</span></td><td>global</td><td>20.5</td></tr>
                                    <tr><td><code>z</code></td><td><span class="badge bg-info">int</span></td><td>global</td><td>15</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4 border-primary">
                <div class="card-header bg-gradient text-white" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <h4 class="mb-0"><i class="fas fa-layer-group me-2"></i>Complete Example: All Phases Together</h4>
                </div>
                <div class="card-body">
                    <h5>Source Code:</h5>
                    <pre class="bg-light p-3 rounded"><code>result = num1 + 10</code></pre>
                    
                    <div class="accordion mt-4" id="phasesAccordion">
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#phase1">
                                    Phase 1: Lexical Analysis
                                </button>
                            </h2>
                            <div id="phase1" class="accordion-collapse collapse show" data-bs-parent="#phasesAccordion">
                                <div class="accordion-body">
                                    <strong>Tokens:</strong> IDENTIFIER(result), OPERATOR(=), IDENTIFIER(num1), OPERATOR(+), CONSTANT(10)
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#phase2">
                                    Phase 2: Syntax Analysis
                                </button>
                            </h2>
                            <div id="phase2" class="accordion-collapse collapse" data-bs-parent="#phasesAccordion">
                                <div class="accordion-body">
                                    <pre class="text-center">      =
     / \
    /   \
result   +
        / \
     num1  10</pre>
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#phase3">
                                    Phase 3: Semantic Analysis
                                </button>
                            </h2>
                            <div id="phase3" class="accordion-collapse collapse" data-bs-parent="#phasesAccordion">
                                <div class="accordion-body">
                                    ✓ Type checking: int + int = int<br>
                                    ✓ Variable num1 is declared<br>
                                    ✓ Assignment is valid
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#phase4">
                                    Phase 4: Intermediate Code
                                </button>
                            </h2>
                            <div id="phase4" class="accordion-collapse collapse" data-bs-parent="#phasesAccordion">
                                <div class="accordion-body">
                                    <pre>t1 = num1 + 10
result = t1</pre>
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#phase5">
                                    Phase 5: Optimization
                                </button>
                            </h2>
                            <div id="phase5" class="accordion-collapse collapse" data-bs-parent="#phasesAccordion">
                                <div class="accordion-body">
                                    <pre>result = num1 + 10  // Direct assignment (eliminated temporary)</pre>
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#phase6">
                                    Phase 6: Code Generation
                                </button>
                            </h2>
                            <div id="phase6" class="accordion-collapse collapse" data-bs-parent="#phasesAccordion">
                                <div class="accordion-body">
                                    <pre class="bg-dark text-light p-3">LOAD  R1, num1
LOAD  R2, #10
ADD   R1, R1, R2
STORE result, R1</pre>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mb-4">
                <a asp-action="AllPhases" class="btn btn-primary btn-lg">
                    <i class="fas fa-play me-2"></i>Try Interactive Demo
                </a>
                <button class="btn btn-success btn-lg ms-2" onclick="window.print()">
                    <i class="fas fa-download me-2"></i>Export to PDF
                </button>
            </div>
        </div>
    </div>
</div>
