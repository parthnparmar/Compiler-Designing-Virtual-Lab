@model AllPhasesModel
@{
    ViewData["Title"] = "All Compiler Phases";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-3"><i class="fas fa-layer-group me-2"></i>All Compiler Phases</h2>
            <p class="lead">Demonstrate all major phases of compilation for a given statement</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-keyboard me-2"></i>Input Statement</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-action="AllPhases">
                        <div class="mb-3">
                            <label class="form-label">Enter Statement:</label>
                            <textarea class="form-control font-monospace" name="statement" rows="4" placeholder="Example: x = a + 5">@Model?.Statement</textarea>
                            <small class="form-text text-muted">Enter an assignment statement (e.g., x = a + 5)</small>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-cogs me-2"></i>Process All Phases
                        </button>
                    </form>

                    @if (ViewData.ModelState.ErrorCount > 0)
                    {
                        <div class="alert alert-danger mt-3">
                            @Html.ValidationSummary()
                        </div>
                    }

                    <div class="mt-4">
                        <h6 class="text-muted">Examples:</h6>
                        <div class="list-group list-group-flush">
                            <button class="list-group-item list-group-item-action" onclick="document.querySelector('textarea[name=statement]').value='x = a + 5'">
                                <code>x = a + 5</code>
                            </button>
                            <button class="list-group-item list-group-item-action" onclick="document.querySelector('textarea[name=statement]').value='result = num1 * 2'">
                                <code>result = num1 * 2</code>
                            </button>
                            <button class="list-group-item list-group-item-action" onclick="document.querySelector('textarea[name=statement]').value='y = x - 10'">
                                <code>y = x - 10</code>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (Model != null && Model.Tokens != null)
        {
            <div class="col-lg-8">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">1️⃣ Lexical Analysis</h5>
                    </div>
                    <div class="card-body">
                        <h6 class="text-muted mb-3">Tokens Identified:</h6>
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>#</th>
                                        <th>Token Type</th>
                                        <th>Lexeme</th>
                                        <th>Line</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.Tokens.Count; i++)
                                    {
                                        var token = Model.Tokens[i];
                                        var badgeClass = token.Type switch
                                        {
                                            "KEYWORD" => "bg-primary",
                                            "IDENTIFIER" => "bg-success",
                                            "CONSTANT" => "bg-warning",
                                            "OPERATOR" => "bg-info",
                                            _ => "bg-secondary"
                                        };
                                        <tr>
                                            <td>@(i + 1)</td>
                                            <td><span class="badge @badgeClass">@token.Type</span></td>
                                            <td><code>@token.Value</code></td>
                                            <td>@token.Line</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">2️⃣ Syntax Analysis (Parse Tree)</h5>
                    </div>
                    <div class="card-body">
                        <pre class="bg-light p-4 rounded text-center" style="font-family: 'Courier New', monospace; font-size: 1.1rem; line-height: 1.8;">@Model.ParseTree</pre>
                    </div>
                </div>

                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="mb-0">3️⃣ Semantic Analysis</h5>
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush">
                            @foreach (var check in Model.SemanticAnalysis!)
                            {
                                <li class="list-group-item">
                                    <i class="fas fa-check-circle text-success me-2"></i>@check
                                </li>
                            }
                        </ul>
                    </div>
                </div>

                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">4️⃣ Intermediate Code Generation (TAC)</h5>
                    </div>
                    <div class="card-body">
                        <pre class="bg-light p-3 rounded"><code>@string.Join("\n", Model.IntermediateCode!)</code></pre>
                    </div>
                </div>

                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-danger text-white">
                        <h5 class="mb-0">5️⃣ Code Optimization</h5>
                    </div>
                    <div class="card-body">
                        <h6 class="text-muted mb-2">Optimized Code:</h6>
                        <pre class="bg-light p-3 rounded"><code>@string.Join("\n", Model.OptimizedCode!)</code></pre>
                    </div>
                </div>

                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0">6️⃣ Code Generation (Assembly)</h5>
                    </div>
                    <div class="card-body">
                        <pre class="bg-dark text-light p-3 rounded"><code>@string.Join("\n", Model.TargetCode!)</code></pre>
                    </div>
                </div>

                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">7️⃣ Symbol Table</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        <th>Name</th>
                                        <th>Type</th>
                                        <th>Scope</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var symbol in Model.SymbolTable!)
                                    {
                                        <tr>
                                            <td><code>@symbol.Name</code></td>
                                            <td><span class="badge bg-info">@symbol.Type</span></td>
                                            <td>@symbol.Scope</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="text-center mb-4">
                    <button class="btn btn-success btn-lg" onclick="window.print()">
                        <i class="fas fa-download me-2"></i>Export to PDF
                    </button>
                </div>
            </div>
        }
    </div>
</div>
