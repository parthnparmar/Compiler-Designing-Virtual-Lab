@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-body text-center py-5">
                    <h1 class="display-4 mb-3">
                        <i class="fas fa-microchip"></i> Compiler Design Virtual Lab
                    </h1>
                    <p class="lead">Complete simulation of all compiler phases with step-by-step solutions</p>
                </div>
            </div>
        </div>
    </div>

    <h3 class="mb-4"><i class="fas fa-project-diagram"></i> Finite Automata</h3>
    <div class="row mb-4">
        <div class="col-md-6 col-lg-3 mb-4">
            <a asp-action="RegexToNfa" class="text-decoration-none">
                <div class="module-card">
                    <i class="fas fa-project-diagram"></i>
                    <h4>Regex → NFA</h4>
                    <p class="text-muted">Thompson's Construction</p>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-3 mb-4">
            <a asp-action="NfaToDfa" class="text-decoration-none">
                <div class="module-card">
                    <i class="fas fa-exchange-alt"></i>
                    <h4>NFA → DFA</h4>
                    <p class="text-muted">Subset Construction</p>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-3 mb-4">
            <a asp-action="DirectDfa" class="text-decoration-none">
                <div class="module-card">
                    <i class="fas fa-sitemap"></i>
                    <h4>Direct DFA</h4>
                    <p class="text-muted">Syntax Tree Method</p>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-3 mb-4">
            <a asp-action="DfaMinimization" class="text-decoration-none">
                <div class="module-card">
                    <i class="fas fa-compress"></i>
                    <h4>DFA Minimization</h4>
                    <p class="text-muted">Partition Method</p>
                </div>
            </a>
        </div>
    </div>

    <h3 class="mb-4"><i class="fas fa-search"></i> Analysis Phase</h3>
    <div class="row mb-4">
        <div class="col-md-6 col-lg-4 mb-4">
            <a asp-action="LexicalAnalyzer" class="text-decoration-none">
                <div class="module-card">
                    <i class="fas fa-search"></i>
                    <h4>Lexical Analyzer</h4>
                    <p class="text-muted">Tokenization & Symbol Table</p>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-4 mb-4">
            <a asp-action="LL1Parser" class="text-decoration-none">
                <div class="module-card">
                    <i class="fas fa-stream"></i>
                    <h4>LL(1) Parser</h4>
                    <p class="text-muted">Top-Down Parsing</p>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-4 mb-4">
            <a asp-action="SLRParser" class="text-decoration-none">
                <div class="module-card">
                    <i class="fas fa-layer-group"></i>
                    <h4>SLR Parser</h4>
                    <p class="text-muted">Bottom-Up Parsing</p>
                </div>
            </a>
        </div>
    </div>

    <h3 class="mb-4"><i class="fas fa-cogs"></i> Code Generation & Optimization</h3>
    <div class="row mb-4">
        <div class="col-md-6 col-lg-4 mb-4">
            <a asp-action="ThreeAddressCode" class="text-decoration-none">
                <div class="module-card">
                    <i class="fas fa-code-branch"></i>
                    <h4>Three Address Code</h4>
                    <p class="text-muted">TAC, Quadruples, Triples</p>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-4 mb-4">
            <a asp-action="CodeOptimization" class="text-decoration-none">
                <div class="module-card">
                    <i class="fas fa-rocket"></i>
                    <h4>Code Optimization</h4>
                    <p class="text-muted">Constant Folding, CSE, etc.</p>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-4 mb-4">
            <a asp-action="CodeGeneration" class="text-decoration-none">
                <div class="module-card">
                    <i class="fas fa-cogs"></i>
                    <h4>Code Generation</h4>
                    <p class="text-muted">Basic Blocks & DAG</p>
                </div>
            </a>
        </div>
    </div>

    <h3 class="mb-4"><i class="fas fa-star"></i> Complete Demo</h3>
    <div class="row mb-4">
        <div class="col-md-6 mb-4">
            <a asp-action="AllPhases" class="text-decoration-none">
                <div class="module-card featured-card">
                    <i class="fas fa-layer-group"></i>
                    <h4>All Compiler Phases</h4>
                    <p class="text-muted">Interactive demonstration of all 7 phases</p>
                </div>
            </a>
        </div>
        <div class="col-md-6 mb-4">
            <a asp-action="CompilerTheory" class="text-decoration-none">
                <div class="module-card featured-card">
                    <i class="fas fa-book"></i>
                    <h4>Theory & Examples</h4>
                    <p class="text-muted">Complete theory with practical examples</p>
                </div>
            </a>
        </div>
    </div>
</div>

<div class="export-section">
    <button class="btn btn-primary btn-float" onclick="window.scrollTo({top: 0, behavior: 'smooth'})" title="Back to Top">
        <i class="fas fa-arrow-up"></i>
    </button>
</div>
